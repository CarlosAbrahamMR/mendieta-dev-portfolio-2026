---
import MainLayout from "../layouts/MainLayout.astro";

const title = "Carlos Mendieta | Frontend Portfolio (Astro)";
const description =
  "Portfolio tecnico en Astro + Tailwind + JavaScript: rendimiento web, SEO tecnico, CSS moderno y Open Source.";
const canonical = "https://CarlosAbrahamMR.github.io/portfolio/";
---

<MainLayout title={title} description={description} canonical={canonical}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      name: "Carlos Abraham Mendieta Robledo",
      jobTitle: "Frontend Developer",
      email: "mailto:carlos.abraham2000@gmail.com",
      sameAs: ["https://github.com/CarlosAbrahamMR", "https://linkedin.com/in/carlosabrahammr"],
      knowsAbout: ["Astro", "JavaScript", "Tailwind CSS", "Web Performance", "Technical SEO"]
    })} />
  </Fragment>

  <header class="sticky top-0 z-20 border-b border-stroke/70 bg-night/85 px-4 py-3 backdrop-blur">
    <div class="mx-auto flex w-full max-w-6xl flex-wrap items-center justify-between gap-3">
      <a href="#inicio" class="font-mono text-sm font-bold text-mint">CMR//AstroPortfolio</a>
      <nav class="flex flex-wrap gap-4 text-sm text-ink/80">
        <a href="#proyectos" class="hover:text-ink">Proyectos</a>
        <a href="#senal" class="hover:text-ink">Senal tecnica</a>
        <a href="#seo" class="hover:text-ink">SEO</a>
        <a href="#contacto" class="hover:text-ink">Contacto</a>
      </nav>
      <button
        id="flagToggle"
        type="button"
        class="rounded-full border border-mint px-3 py-1.5 text-xs font-semibold text-mint"
      >
        Activar Hiring Mode
      </button>
    </div>
  </header>

  <main id="inicio" class="mx-auto w-[min(100%-2rem,72rem)] py-10">
    <section class="scroll-reveal">
      <p class="font-mono text-sm text-sun">Astro + Vanilla JS + HTML + CSS + Tailwind</p>
      <h1 class="mt-2 text-4xl font-extrabold leading-tight md:text-6xl">
        Frontend enfocado en rendimiento real y seleccion tecnica
      </h1>
      <p class="mt-4 max-w-3xl text-ink/80">
        Portfolio disenado para demostrar lo que importa en procesos tipo La Velada: rol claro por
        proyecto, stack concreto, decisiones de performance, SEO tecnico y contribuciones Open Source.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a class="rounded-full bg-mint px-4 py-2 text-sm font-bold text-night" href="https://github.com/CarlosAbrahamMR" target="_blank" rel="noreferrer">GitHub</a>
        <a class="rounded-full border border-stroke px-4 py-2 text-sm font-bold text-ink" href="https://linkedin.com/in/carlosabrahammr" target="_blank" rel="noreferrer">LinkedIn</a>
      </div>
    </section>

    <section id="proyectos" class="scroll-reveal mt-16">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <h2 class="text-3xl font-bold">Proyectos destacados</h2>
        <div class="flex flex-wrap gap-2">
          <button class="chip rounded-full border border-stroke px-3 py-1 text-sm text-ink is-active" data-filter="all">Todos</button>
          <button class="chip rounded-full border border-stroke px-3 py-1 text-sm text-ink" data-filter="astro">Astro</button>
          <button class="chip rounded-full border border-stroke px-3 py-1 text-sm text-ink" data-filter="performance">Performance</button>
          <button class="chip rounded-full border border-stroke px-3 py-1 text-sm text-ink" data-filter="react">React</button>
        </div>
      </div>

      <div class="mt-6 grid gap-4 md:grid-cols-2">
        <article class="project rounded-2xl border border-stroke bg-slate-900/50 p-5" data-tags="astro performance">
          <p class="font-mono text-xs text-mint">Landing de alto trafico</p>
          <h3 class="mt-2 text-xl font-bold">Fight Night Landing</h3>
          <p class="mt-2 text-sm text-ink/80"><strong>Rol:</strong> Frontend principal (UI + optimizacion + SEO).</p>
          <p class="mt-1 text-sm text-ink/80"><strong>Stack:</strong> Astro, JavaScript, Tailwind, endpoints API.</p>
          <p class="mt-1 text-sm text-ink/80"><strong>Impacto:</strong> LCP 3.2s -> 1.8s y JS inicial -41%.</p>
        </article>

        <article class="project rounded-2xl border border-stroke bg-slate-900/50 p-5" data-tags="react performance">
          <p class="font-mono text-xs text-mint">Dashboard con datos vivos</p>
          <h3 class="mt-2 text-xl font-bold">SIPE UI Refresh</h3>
          <p class="mt-2 text-sm text-ink/80"><strong>Rol:</strong> Mejora de navegacion y accesibilidad.</p>
          <p class="mt-1 text-sm text-ink/80"><strong>Stack:</strong> React, Tailwind, APIs REST.</p>
          <p class="mt-1 text-sm text-ink/80"><strong>Impacto:</strong> UX mas fluida y componentes reutilizables.</p>
        </article>
      </div>
    </section>

    <section id="senal" class="scroll-reveal mt-16 grid gap-6 md:grid-cols-2">
      <article class="rounded-2xl border border-stroke bg-slate-900/50 p-5">
        <h2 class="text-2xl font-bold">CSS moderno > imagen pesada</h2>
        <p class="mt-3 text-sm text-ink/80">
          Uso <code>mask-image + linear-gradient</code> para difuminar bordes y generar efectos
          visuales programaticos sin depender de assets editados en Photoshop.
        </p>
        <div class="fighter-mask mt-4 h-44 w-full"></div>
      </article>

      <article class="rounded-2xl border border-stroke bg-slate-900/50 p-5">
        <h2 class="text-2xl font-bold">Animaciones ligeras</h2>
        <p class="mt-3 text-sm text-ink/80">
          Scroll-linked animations con View Timeline API en CSS, evitando librerias JS pesadas para
          efectos de entrada de secciones.
        </p>
        <p class="mt-3 text-xs text-sun">
          Nota: tambien integro utilidades de <code>@midudev/tailwind-animations</code> cuando el
          proyecto las requiere.
        </p>
      </article>
    </section>

    <section id="seo" class="scroll-reveal mt-16 rounded-2xl border border-stroke bg-slate-900/50 p-6">
      <h2 class="text-3xl font-bold">SEO tecnico aplicado</h2>
      <ul class="mt-4 list-disc space-y-2 pl-5 text-sm text-ink/85">
        <li>Open Graph completo para shares en redes.</li>
        <li>Twitter Card `summary_large_image` correctamente configurada.</li>
        <li>URL canonica para evitar contenido duplicado.</li>
        <li>Schema.org Person en JSON-LD para enriquecer contexto semantico.</li>
      </ul>
    </section>

    <section id="hiring-lab" class="scroll-reveal mt-16 hidden rounded-2xl border border-mint/70 bg-mint/10 p-6">
      <h2 class="text-2xl font-bold text-mint">Hiring Mode (Feature Flag)</h2>
      <p class="mt-2 text-sm text-ink/85">
        Este bloque se habilita con <code>?ff=hiring</code> o con el boton superior para simular
        despliegues continuos con funcionalidad oculta.
      </p>
    </section>
  </main>

  <footer id="contacto" class="mx-auto mt-8 w-[min(100%-2rem,72rem)] border-t border-stroke py-8">
    <p class="text-sm text-ink/80">Disponible para trabajo remoto frontend y colaboracion Open Source.</p>
    <p class="mt-2 text-sm">
      <a class="text-sun" href="mailto:carlos.abraham2000@gmail.com">carlos.abraham2000@gmail.com</a>
    </p>
  </footer>

  <script is:inline>
    const chips = document.querySelectorAll(".chip");
    const projects = document.querySelectorAll(".project");
    const flagToggle = document.querySelector("#flagToggle");
    const hiringLab = document.querySelector("#hiring-lab");
    const KEY = "portfolio_hiring_mode";

    const applyFilter = (value) => {
      projects.forEach((project) => {
        const tags = project.dataset.tags || "";
        const show = value === "all" || tags.includes(value);
        project.style.display = show ? "block" : "none";
      });
    };

    chips.forEach((chip) => {
      chip.addEventListener("click", () => {
        chips.forEach((c) => c.classList.remove("is-active", "bg-slate-700"));
        chip.classList.add("is-active", "bg-slate-700");
        applyFilter(chip.dataset.filter);
      });
    });

    const setHiringMode = (enabled) => {
      hiringLab?.classList.toggle("hidden", !enabled);
      if (flagToggle) {
        flagToggle.textContent = enabled ? "Desactivar Hiring Mode" : "Activar Hiring Mode";
      }
      localStorage.setItem(KEY, enabled ? "1" : "0");
    };

    const fromUrl = new URLSearchParams(window.location.search).get("ff") === "hiring";
    const fromStorage = localStorage.getItem(KEY) === "1";
    setHiringMode(fromUrl || fromStorage);

    flagToggle?.addEventListener("click", () => {
      const current = localStorage.getItem(KEY) === "1";
      setHiringMode(!current);
    });
  </script>
</MainLayout>
