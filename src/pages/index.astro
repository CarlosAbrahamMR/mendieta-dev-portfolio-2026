---
import MainLayout from "../layouts/MainLayout.astro";

const title = "Carlos Mendieta | Frontend Portfolio";
const description =
  "Portfolio frontend en Astro + Tailwind + JavaScript. Proyectos reales en produccion, texto honesto y foco en rendimiento.";
const canonical = "https://CarlosAbrahamMR.github.io/mendieta-dev-portfolio-2026/";
---

<MainLayout title={title} description={description} canonical={canonical}>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        name: "Carlos Abraham Mendieta Robledo",
        jobTitle: "Frontend Developer",
        email: "mailto:carlos.abraham2000@gmail.com",
        sameAs: ["https://github.com/CarlosAbrahamMR", "https://linkedin.com/in/carlosabrahammr"],
        knowsAbout: [
          "Astro",
          "JavaScript",
          "Tailwind CSS",
          "Web Performance",
          "Technical SEO",
          "Frontend Architecture"
        ]
      })}
    />
  </Fragment>

  <header class="sticky top-0 z-30 border-b border-stroke/70 bg-[#0a122d]/80 px-4 py-3 backdrop-blur">
    <div class="mx-auto flex w-full max-w-6xl flex-wrap items-center justify-between gap-3">
      <a href="#inicio" class="font-mono text-xs font-semibold tracking-widest text-mint">
        CMR//CRAFTED-WEB
      </a>
      <nav class="flex flex-wrap items-center gap-4 text-sm text-ink/80">
        <a class="hover:text-ink" href="#proyectos">Proyectos</a>
        <a class="hover:text-ink" href="#proceso">Proceso</a>
        <a class="hover:text-ink" href="#experiencia">Experiencia</a>
        <a class="hover:text-ink" href="#senal">Senal tecnica</a>
        <a class="hover:text-ink" href="#contacto">Contacto</a>
      </nav>
      <button
        id="flagToggle"
        type="button"
        class="cta-pulse rounded-full border border-mint/80 px-3 py-1.5 text-xs font-semibold text-mint"
      >
        Activar Hiring Mode
      </button>
    </div>
  </header>

  <main id="inicio" class="mx-auto w-[min(100%-2rem,72rem)] py-10">
    <section class="reveal view-rise grid items-center gap-8 md:grid-cols-[1.3fr_1fr]">
      <div>
        <p class="kicker">Astro + Vanilla JS + Tailwind + CSS moderno</p>
        <h1 class="mt-2 text-4xl font-extrabold leading-tight md:text-6xl">
          Desarrollo frontend con enfoque en claridad, rendimiento y detalle.
          <span class="text-mint">Sin humo: lo que ves aqui es lo que he construido.</span>
        </h1>
        <p class="mt-5 max-w-3xl text-ink/80">
          Soy Carlos, desarrollador frontend junior. En este portfolio muestro proyectos reales, el
          tipo de tareas que he hecho y los resultados que puedo explicar en entrevista. Todavia
          estoy creciendo, pero trabajo con criterio tecnico y muchas ganas de mejorar.
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          <a
            class="rounded-full bg-mint px-4 py-2 text-sm font-bold text-night transition hover:translate-y-[-1px]"
            href="https://github.com/CarlosAbrahamMR"
            target="_blank"
            rel="noreferrer"
          >
            Ver GitHub
          </a>
          <a
            class="rounded-full border border-stroke px-4 py-2 text-sm font-bold text-ink transition hover:border-mint/70"
            href="https://linkedin.com/in/carlosabrahammr"
            target="_blank"
            rel="noreferrer"
          >
            Conectar en LinkedIn
          </a>
          <a
            class="rounded-full border border-stroke px-4 py-2 text-sm font-bold text-ink transition hover:border-sun/70"
            href="mailto:carlos.abraham2000@gmail.com"
          >
            Contacto directo
          </a>
        </div>
      </div>
      <div class="hero-orb mx-auto w-full max-w-xs md:max-w-sm"></div>
    </section>

    <section class="mt-10 grid gap-4 sm:grid-cols-3">
      <article class="soft-card reveal glass rounded-2xl p-4" data-delay="1">
        <p class="kicker text-sun">Focus</p>
        <p class="mt-2 text-lg font-bold">Rendimiento web practico</p>
        <p class="mt-1 text-sm text-ink/75">Cuidar carga inicial, estabilidad visual y experiencia real.</p>
      </article>
      <article class="soft-card reveal glass rounded-2xl p-4" data-delay="2">
        <p class="kicker text-sun">Stack</p>
        <p class="mt-2 text-lg font-bold">Astro + Tailwind + JS</p>
        <p class="mt-1 text-sm text-ink/75">Base ligera para landings y componentes de frontend modernos.</p>
      </article>
      <article class="soft-card reveal glass rounded-2xl p-4" data-delay="3">
        <p class="kicker text-sun">Mindset</p>
        <p class="mt-2 text-lg font-bold">Aprendizaje constante</p>
        <p class="mt-1 text-sm text-ink/75">Me gusta iterar, recibir feedback y subir el nivel en cada entrega.</p>
      </article>
    </section>

    <section id="proyectos" class="mt-20">
      <div class="reveal view-rise">
        <p class="kicker">Trabajo destacado</p>
        <h2 class="section-title mt-2">Proyectos reales y descripcion honesta de mi rol</h2>
        <p class="mt-3 max-w-3xl text-ink/80">
          Comparto solo lo que puedo respaldar. Cuando un proyecto es privado, muestro enlaces
          publicos y explico claramente que parte fue mi responsabilidad.
        </p>
      </div>

      <div class="mt-6 flex flex-wrap gap-2 reveal" data-delay="1">
        <button class="chip rounded-full border border-stroke px-3 py-1 text-sm text-ink is-active bg-slate-700/50" data-filter="all">
          Todos
        </button>
        <button class="chip rounded-full border border-stroke px-3 py-1 text-sm text-ink" data-filter="astro">
          Astro
        </button>
        <button class="chip rounded-full border border-stroke px-3 py-1 text-sm text-ink" data-filter="performance">
          Performance
        </button>
        <button class="chip rounded-full border border-stroke px-3 py-1 text-sm text-ink" data-filter="react">
          React
        </button>
        <button class="chip rounded-full border border-stroke px-3 py-1 text-sm text-ink" data-filter="seo">
          SEO
        </button>
      </div>

      <div class="mt-6 grid gap-4 md:grid-cols-2">
        <article class="project project-card reveal glass rounded-2xl p-5" data-tags="react performance" data-delay="1">
          <p class="kicker text-mint">Proyecto real en produccion</p>
          <h3 class="mt-2 text-2xl font-bold">Sistema SIPE</h3>
          <p class="mt-3 text-sm text-ink/85">
            <strong>Rol:</strong> participe como practicante frontend/UI en mejoras de navegacion y
            claridad visual. No desarrolle todo el sistema desde cero.
          </p>
          <p class="mt-1 text-sm text-ink/85">
            <strong>Stack:</strong> frontend web con JavaScript, componentes de interfaz y consumo de APIs.
          </p>
          <p class="mt-1 text-sm text-ink/85">
            <strong>Resultado:</strong> mejor lectura de pantallas clave y flujo de acceso mas claro.
          </p>
          <div class="mt-4">
            <a
              class="rounded-full border border-mint/50 px-3 py-1.5 text-xs font-semibold text-mint hover:border-mint"
              href="https://systemsipe.com/login"
              target="_blank"
              rel="noreferrer"
            >
              Ver login en produccion
            </a>
          </div>
        </article>

        <article class="project project-card reveal glass rounded-2xl p-5" data-tags="performance" data-delay="2">
          <p class="kicker text-mint">Proyecto real en produccion</p>
          <h3 class="mt-2 text-2xl font-bold">HK Donga Fleet Monitoring</h3>
          <p class="mt-3 text-sm text-ink/85">
            <strong>Rol:</strong> apoyo en ajustes de interfaz y flujo de acceso para una plataforma
            operativa en uso.
          </p>
          <p class="mt-1 text-sm text-ink/85">
            <strong>Stack:</strong> aplicacion web con formularios de login, frontend y conexion con backend existente.
          </p>
          <p class="mt-1 text-sm text-ink/85">
            <strong>Resultado:</strong> experiencia mas consistente en acceso y navegacion inicial.
          </p>
          <div class="mt-4">
            <a
              class="rounded-full border border-mint/50 px-3 py-1.5 text-xs font-semibold text-mint hover:border-mint"
              href="https://hk-donga.fleetmonitoring.online/log-in"
              target="_blank"
              rel="noreferrer"
            >
              Ver login en produccion
            </a>
          </div>
        </article>

        <article class="project project-card reveal glass rounded-2xl p-5 md:col-span-2" data-tags="astro seo performance" data-delay="1">
          <p class="kicker text-mint">Proyecto personal</p>
          <h3 class="mt-2 text-2xl font-bold">Este portfolio (Astro)</h3>
          <p class="mt-3 text-sm text-ink/85">
            <strong>Rol:</strong> disenio y desarrollo completo del sitio para mostrar experiencia real
            de forma clara.
          </p>
          <p class="mt-1 text-sm text-ink/85">
            <strong>Stack:</strong> Astro, Tailwind, JavaScript, SEO tecnico (OG, Twitter Cards, canonical).
          </p>
          <p class="mt-1 text-sm text-ink/85">
            <strong>Resultado:</strong> sitio ligero, responsive y mantenible para compartir en procesos de seleccion.
          </p>
          <div class="mt-4">
            <a
              class="rounded-full border border-mint/50 px-3 py-1.5 text-xs font-semibold text-mint hover:border-mint"
              href="https://github.com/CarlosAbrahamMR/mendieta-dev-portfolio-2026"
              target="_blank"
              rel="noreferrer"
            >
              Ver codigo del portfolio
            </a>
          </div>
        </article>
      </div>
    </section>

    <section id="proceso" class="mt-20">
      <div class="reveal view-rise">
        <p class="kicker">Forma de trabajo</p>
        <h2 class="section-title mt-2">Como convierto ideas en una experiencia cuidada</h2>
      </div>
      <div class="mt-6 grid gap-4 md:grid-cols-2">
        <article class="soft-card reveal glass rounded-2xl p-5" data-delay="1">
          <p class="kicker text-mint">01 Descubrir</p>
          <p class="mt-2 text-lg font-bold">Objetivo y contexto primero</p>
          <p class="mt-1 text-sm text-ink/80">
            Defino que problema resolvemos, para quien y que metricas importan.
          </p>
        </article>
        <article class="soft-card reveal glass rounded-2xl p-5" data-delay="2">
          <p class="kicker text-mint">02 Prototipar</p>
          <p class="mt-2 text-lg font-bold">UI con ritmo y jerarquia</p>
          <p class="mt-1 text-sm text-ink/80">
            Estructuro secciones, tono visual y comportamiento responsivo desde el inicio.
          </p>
        </article>
        <article class="soft-card reveal glass rounded-2xl p-5" data-delay="1">
          <p class="kicker text-mint">03 Optimizar</p>
          <p class="mt-2 text-lg font-bold">Rendimiento como criterio</p>
          <p class="mt-1 text-sm text-ink/80">
            Reduzco peso, postergo carga no critica y cuido la navegacion percibida.
          </p>
        </article>
        <article class="soft-card reveal glass rounded-2xl p-5" data-delay="2">
          <p class="kicker text-mint">04 Publicar</p>
          <p class="mt-2 text-lg font-bold">Deploy seguro y medible</p>
          <p class="mt-1 text-sm text-ink/80">
            Activo feature flags, valido SEO y dejo monitoreo para iterar rapido.
          </p>
        </article>
      </div>
    </section>

    <section id="experiencia" class="mt-20">
      <div class="reveal view-rise">
        <p class="kicker">Recorrido</p>
        <h2 class="section-title mt-2">Experiencia y evolucion</h2>
      </div>
      <div class="relative mt-6 pl-8">
        <div class="timeline-line" aria-hidden="true"></div>

        <article class="reveal relative mb-8 flex gap-4" data-delay="1">
          <span class="timeline-dot"></span>
          <div class="glass soft-card w-full rounded-2xl p-5">
            <p class="text-xs text-sun">Ago 2025</p>
            <h3 class="text-xl font-bold">Practicante Frontend & UI - SIPE</h3>
            <p class="mt-1 text-sm text-ink/80">
              Mejora de dashboard y navegacion con enfoque en usabilidad, accesibilidad y claridad visual.
            </p>
          </div>
        </article>

        <article class="reveal relative mb-8 flex gap-4" data-delay="2">
          <span class="timeline-dot"></span>
          <div class="glass soft-card w-full rounded-2xl p-5">
            <p class="text-xs text-sun">Oct 2024 - Presente</p>
            <h3 class="text-xl font-bold">Practicante Desarrollo y Automatizacion</h3>
            <p class="mt-1 text-sm text-ink/80">
              Integraciones con webhooks y flujos de datos para mejorar estabilidad bajo carga.
            </p>
          </div>
        </article>

        <article class="reveal relative flex gap-4" data-delay="3">
          <span class="timeline-dot"></span>
          <div class="glass soft-card w-full rounded-2xl p-5">
            <p class="text-xs text-sun">Jul 2021 - Ago 2023</p>
            <h3 class="text-xl font-bold">Practicante Desarrollo Web - Centro de Desarrollo UAQ</h3>
            <p class="mt-1 text-sm text-ink/80">
              Trabajo fullstack, despliegues en AWS y mejoras de experiencia frontend.
            </p>
          </div>
        </article>
      </div>
    </section>

    <section id="senal" class="mt-20 grid gap-4 md:grid-cols-2">
      <article class="soft-card reveal view-rise glass rounded-2xl p-6">
        <p class="kicker">CSS moderno</p>
        <h2 class="section-title mt-2">Mas codigo, menos imagen pesada</h2>
        <p class="mt-3 text-sm text-ink/80">
          Uso <code>mask-image + linear-gradient</code> para crear bordes difuminados y efectos
          visuales adaptables sin assets gigantes.
        </p>
        <div class="fighter-mask mt-4 h-44 w-full"></div>
      </article>

      <article class="soft-card reveal view-rise glass rounded-2xl p-6" data-delay="1">
        <p class="kicker">Animacion ligera</p>
        <h2 class="section-title mt-2">Movimiento con intencion</h2>
        <p class="mt-3 text-sm text-ink/80">
          Combino View Timeline API y animaciones suaves para guiar la lectura sin cargar JS pesado.
        </p>
        <ul class="mt-4 list-disc space-y-1 pl-5 text-sm text-ink/80">
          <li>Entrada por seccion con scroll.</li>
          <li>Hover progresivo y feedback visual en cards.</li>
          <li>Respeto por `prefers-reduced-motion`.</li>
        </ul>
      </article>
    </section>

    <section id="hiring-lab" class="reveal mt-20 hidden rounded-2xl border border-mint/70 bg-mint/10 p-6">
      <p class="kicker text-mint">Feature Flag</p>
      <h2 class="section-title mt-2 text-mint">Hiring Mode activo</h2>
      <p class="mt-2 text-sm text-ink/85">
        Este bloque aparece con <code>?ff=hiring</code> o desde el boton superior. Simula despliegues
        continuos con funcionalidad oculta.
      </p>
    </section>

    <section id="contacto" class="reveal mt-20">
      <div class="glass soft-card rounded-3xl p-7 md:p-10">
        <p class="kicker">Cierre</p>
        <h2 class="section-title mt-2">Gracias por llegar hasta aqui</h2>
        <p class="mt-3 max-w-2xl text-ink/80">
          Si buscas a alguien que combine criterio tecnico, velocidad de ejecucion y gusto por los
          detalles, me encantara colaborar en tu equipo.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a class="rounded-full bg-mint px-4 py-2 text-sm font-bold text-night" href="mailto:carlos.abraham2000@gmail.com">
            Escribeme por email
          </a>
          <a
            class="rounded-full border border-stroke px-4 py-2 text-sm font-bold text-ink"
            href="https://github.com/CarlosAbrahamMR"
            target="_blank"
            rel="noreferrer"
          >
            Revisar repositorios
          </a>
        </div>
      </div>
    </section>
  </main>

  <footer class="mx-auto mt-10 w-[min(100%-2rem,72rem)] border-t border-stroke py-7 text-xs text-ink/60">
    <p>&copy; {new Date().getFullYear()} Carlos Abraham Mendieta Robledo. Crafted with care.</p>
  </footer>

  <script is:inline>
    const chips = document.querySelectorAll(".chip");
    const projects = document.querySelectorAll(".project");
    const flagToggle = document.querySelector("#flagToggle");
    const hiringLab = document.querySelector("#hiring-lab");
    const KEY = "portfolio_hiring_mode";

    const setFilter = (value) => {
      projects.forEach((project) => {
        const tags = project.dataset.tags || "";
        const match = value === "all" || tags.includes(value);
        project.style.display = match ? "block" : "none";
      });
    };

    chips.forEach((chip) => {
      chip.addEventListener("click", () => {
        chips.forEach((c) => c.classList.remove("is-active", "bg-slate-700/50"));
        chip.classList.add("is-active", "bg-slate-700/50");
        setFilter(chip.dataset.filter);
      });
    });

    const setHiringMode = (enabled) => {
      hiringLab?.classList.toggle("hidden", !enabled);
      if (flagToggle) {
        flagToggle.textContent = enabled ? "Desactivar Hiring Mode" : "Activar Hiring Mode";
      }
      localStorage.setItem(KEY, enabled ? "1" : "0");
    };

    const fromUrl = new URLSearchParams(window.location.search).get("ff") === "hiring";
    const fromStorage = localStorage.getItem(KEY) === "1";
    setHiringMode(fromUrl || fromStorage);

    flagToggle?.addEventListener("click", () => {
      const current = localStorage.getItem(KEY) === "1";
      setHiringMode(!current);
    });

    // Fallback reveal animation for browsers without View Timeline support.
    const revealItems = document.querySelectorAll(".reveal");
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15, rootMargin: "0px 0px -8% 0px" }
    );

    revealItems.forEach((item) => observer.observe(item));
  </script>
</MainLayout>
